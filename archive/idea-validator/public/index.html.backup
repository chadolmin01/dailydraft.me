<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Co-founders - 아이디어 검증</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      max-width: 1100px;
      margin: 0 auto;
      padding: 40px 20px;
      background: #fafafa;
    }
    h1 { text-align: center; margin-bottom: 10px; }
    .subtitle { text-align: center; color: #666; margin-bottom: 40px; }

    .input-section {
      background: #fff;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      margin-bottom: 30px;
    }
    .input-section h3 { margin-bottom: 16px; color: #333; }
    textarea {
      width: 100%;
      height: 180px;
      padding: 16px;
      font-size: 16px;
      border: 2px solid #e0e0e0;
      border-radius: 8px;
      resize: vertical;
      margin-bottom: 20px;
      line-height: 1.6;
    }
    textarea:focus { outline: none; border-color: #4a90d9; }

    /* 난이도 선택 */
    .level-selector {
      margin-bottom: 20px;
    }
    .level-selector label {
      display: block;
      font-size: 14px;
      font-weight: 600;
      color: #333;
      margin-bottom: 12px;
    }
    .level-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    .level-card {
      border: 2px solid #e0e0e0;
      border-radius: 12px;
      padding: 16px;
      cursor: pointer;
      transition: all 0.2s;
      text-align: center;
    }
    .level-card:hover { border-color: #4a90d9; background: #f8faff; }
    .level-card.selected { border-color: #4a90d9; background: #e3f2fd; }
    .level-card.selected .level-icon { background: #4a90d9; }
    .level-icon {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: #e0e0e0;
      margin: 0 auto 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }
    .level-card.sketch .level-icon { background: #a5d6a7; }
    .level-card.sketch.selected .level-icon { background: #4caf50; }
    .level-card.mvp .level-icon { background: #90caf9; }
    .level-card.mvp.selected .level-icon { background: #1976d2; }
    .level-card.investor .level-icon { background: #ffcc80; }
    .level-card.investor.selected .level-icon { background: #f57c00; }
    .level-name { font-weight: 600; font-size: 14px; color: #333; margin-bottom: 4px; }
    .level-desc { font-size: 11px; color: #666; line-height: 1.4; }
    .level-badge {
      display: inline-block;
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 10px;
      margin-top: 8px;
    }
    .level-card.sketch .level-badge { background: #e8f5e9; color: #2e7d32; }
    .level-card.mvp .level-badge { background: #e3f2fd; color: #1565c0; }
    .level-card.investor .level-badge { background: #fff3e0; color: #e65100; }

    button {
      width: 100%;
      padding: 16px;
      font-size: 18px;
      font-weight: 600;
      background: #4a90d9;
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s;
    }
    button:hover { background: #3a7bc8; }
    button:disabled { background: #ccc; cursor: not-allowed; }

    .iteration-badge {
      display: inline-block;
      background: #e3f2fd;
      color: #1565c0;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 13px;
      margin-bottom: 16px;
    }
    .level-indicator {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 13px;
      margin-left: 8px;
    }
    .level-indicator.sketch { background: #e8f5e9; color: #2e7d32; }
    .level-indicator.mvp { background: #e3f2fd; color: #1565c0; }
    .level-indicator.investor { background: #fff3e0; color: #e65100; }

    .loading {
      text-align: center;
      padding: 60px 20px;
      font-size: 18px;
      color: #666;
      display: none;
    }
    .loading.show { display: block; }
    .spinner {
      width: 40px;
      height: 40px;
      border: 4px solid #e0e0e0;
      border-top-color: #4a90d9;
      border-radius: 50%;
      margin: 0 auto 20px;
      animation: spin 1s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .result-section { display: none; }
    .result-section.show { display: block; }

    .average-score {
      text-align: center;
      padding: 30px;
      background: #fff;
      border-radius: 12px;
      margin-bottom: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .average-score .score { font-size: 64px; font-weight: 700; margin-bottom: 10px; }
    .average-score.pass .score { color: #2e7d32; }
    .average-score.fail .score { color: #c62828; }
    .average-score .message { font-size: 18px; line-height: 1.6; }
    .average-score.pass .message { color: #2e7d32; }
    .average-score.fail .message { color: #c62828; }
    .tip { text-align: center; color: #666; font-size: 14px; margin-top: 12px; }

    .score-change { font-size: 16px; margin-top: 8px; }
    .score-change.up { color: #2e7d32; }
    .score-change.down { color: #c62828; }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
    }
    .card {
      background: #fff;
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      transition: all 0.3s;
    }
    .card.has-answer { border: 2px solid #4caf50; }
    .card.score-up { animation: scoreUp 0.5s ease; }
    @keyframes scoreUp {
      0% { transform: scale(1); }
      50% { transform: scale(1.02); box-shadow: 0 4px 20px rgba(76,175,80,0.3); }
      100% { transform: scale(1); }
    }
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
      padding-bottom: 14px;
      border-bottom: 1px solid #eee;
    }
    .card-role { font-size: 13px; font-weight: 600; color: #666; }
    .card-score-wrap { text-align: right; }
    .card-score { font-size: 26px; font-weight: 700; }
    .card-score-change { font-size: 12px; margin-top: 2px; }
    .card-score-change.up { color: #2e7d32; }
    .card-score-change.down { color: #c62828; }
    .card.pm .card-score { color: #1565c0; }
    .card.developer .card-score { color: #6a1b9a; }
    .card.designer .card-score { color: #00838f; }
    .card.investor .card-score { color: #e65100; }

    .card-feedback { font-size: 14px; line-height: 1.6; color: #333; margin-bottom: 14px; }

    .conversation { margin-top: 16px; border-top: 1px dashed #ddd; padding-top: 16px; }
    .chat-bubble {
      padding: 12px;
      border-radius: 12px;
      margin-bottom: 10px;
      font-size: 13px;
      line-height: 1.5;
      animation: fadeIn 0.3s ease;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .chat-bubble.ai {
      background: #f5f5f5;
      border-left: 3px solid #4a90d9;
      cursor: pointer;
      transition: all 0.2s;
    }
    .chat-bubble.ai:hover { background: #e3f2fd; }
    .chat-bubble.ai.answered, .chat-bubble.ai.passed { cursor: default; }
    .chat-bubble.ai.answered:hover { background: #f5f5f5; }
    .chat-bubble.ai.passed { background: #e8f5e9; border-left-color: #4caf50; }
    .chat-bubble.user {
      background: #e8f5e9;
      border-left: 3px solid #4caf50;
      margin-left: 20px;
    }
    .chat-label {
      font-size: 11px;
      font-weight: 600;
      color: #888;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .chat-label .icon {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
    }
    .chat-bubble.ai .icon { background: #4a90d9; color: white; }
    .chat-bubble.user .icon { background: #4caf50; color: white; }
    .chat-content { color: #333; }
    .click-hint { font-size: 11px; color: #1565c0; margin-top: 8px; display: block; }
    .chat-bubble.answered .click-hint, .chat-bubble.passed .click-hint { display: none; }

    .edit-answer {
      font-size: 11px;
      color: #666;
      background: none;
      border: none;
      padding: 4px 8px;
      cursor: pointer;
      width: auto;
      margin-top: 8px;
    }
    .edit-answer:hover { color: #1565c0; text-decoration: underline; background: none; }

    .btn-group { display: flex; gap: 12px; margin-top: 24px; }
    .btn-group button { flex: 1; }
    .btn-secondary { background: #666; }
    .btn-secondary:hover { background: #555; }
    .btn-success { background: #2e7d32; }
    .btn-success:hover { background: #1b5e20; }

    .combined-idea {
      background: #fff;
      border: 2px solid #4a90d9;
      border-radius: 12px;
      margin-bottom: 20px;
      overflow: hidden;
    }
    .combined-header {
      background: #4a90d9;
      color: white;
      padding: 12px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .combined-title { font-weight: 600; font-size: 14px; }
    .combined-count { font-size: 13px; opacity: 0.9; }
    .combined-content {
      padding: 20px;
      font-size: 14px;
      line-height: 1.8;
      color: #333;
      max-height: 300px;
      overflow-y: auto;
    }
    .combined-content .original { color: #333; white-space: pre-wrap; }
    .combined-content .supplement-section { margin-top: 16px; padding-top: 16px; border-top: 1px dashed #ddd; }
    .combined-content .qa-item { margin-bottom: 12px; padding: 12px; background: #f8f9fa; border-radius: 8px; }
    .combined-content .qa-item:last-child { margin-bottom: 0; }
    .combined-content .qa-q { color: #1565c0; font-weight: 500; margin-bottom: 6px; }
    .combined-content .qa-a { color: #2e7d32; padding-left: 12px; border-left: 2px solid #4caf50; }

    .modal-overlay {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.5);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 1000;
      padding: 20px;
    }
    .modal-overlay.show { display: flex; }
    .modal {
      background: #fff;
      border-radius: 16px;
      padding: 30px;
      max-width: 500px;
      width: 100%;
      max-height: 80vh;
      overflow-y: auto;
    }
    .modal h3 { margin-bottom: 8px; color: #333; }
    .modal-role { font-size: 13px; color: #666; margin-bottom: 20px; }
    .modal-question {
      background: #f5f5f5;
      padding: 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-size: 15px;
      line-height: 1.6;
      border-left: 3px solid #4a90d9;
    }
    .modal textarea { height: 100px; margin-bottom: 16px; }
    .modal-buttons { display: flex; gap: 12px; }
    .modal-buttons button { flex: 1; padding: 12px; font-size: 15px; }
    .btn-cancel { background: #e0e0e0; color: #333; }
    .btn-cancel:hover { background: #d0d0d0; }

    .suggestions { margin-bottom: 16px; }
    .suggestions-title { font-size: 13px; color: #666; margin-bottom: 10px; }
    .suggestions-loading { text-align: center; padding: 20px; color: #666; }
    .suggestions-loading .mini-spinner {
      width: 20px; height: 20px;
      border: 2px solid #e0e0e0;
      border-top-color: #4a90d9;
      border-radius: 50%;
      margin: 0 auto 10px;
      animation: spin 1s linear infinite;
    }
    .suggestion-item {
      background: #f5f5f5;
      border: 2px solid transparent;
      border-radius: 8px;
      padding: 12px;
      margin-bottom: 8px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .suggestion-item:hover { background: #e3f2fd; border-color: #4a90d9; }
    .suggestion-item.selected { background: #e3f2fd; border-color: #1565c0; }
    .suggestion-label { font-weight: 600; font-size: 14px; color: #333; margin-bottom: 4px; }
    .suggestion-answer { font-size: 13px; color: #555; line-height: 1.5; }
    .or-divider { text-align: center; color: #999; font-size: 12px; margin: 16px 0 12px; }

    @media (max-width: 600px) {
      .level-cards { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <h1>AI Co-founders</h1>
  <p class="subtitle">4명의 AI 전문가에게 당신의 스타트업 아이디어를 검증받으세요</p>

  <div class="input-section" id="inputSection">
    <div class="iteration-badge" id="iterationBadge" style="display:none;">
      <span id="iterationCount">1</span>차 피칭
      <span class="level-indicator" id="levelIndicator"></span>
    </div>

    <!-- 난이도 선택 -->
    <div class="level-selector">
      <label>검증 난이도를 선택하세요</label>
      <div class="level-cards">
        <div class="level-card sketch" data-level="sketch" onclick="selectLevel('sketch')">
          <div class="level-icon">🌱</div>
          <div class="level-name">아이디어 스케치</div>
          <div class="level-desc">친절한 멘토가<br>기초 질문만 해요</div>
          <span class="level-badge">Fast · 초보자용</span>
        </div>
        <div class="level-card mvp selected" data-level="mvp" onclick="selectLevel('mvp')">
          <div class="level-icon">🚀</div>
          <div class="level-name">MVP 빌딩</div>
          <div class="level-desc">실무진이 현실적인<br>핵심 질문을 던져요</div>
          <span class="level-badge">Standard · 기본</span>
        </div>
        <div class="level-card investor" data-level="investor" onclick="selectLevel('investor')">
          <div class="level-icon">💼</div>
          <div class="level-name">투자자 방어</div>
          <div class="level-desc">VC 심사역이<br>날카롭게 파고들어요</div>
          <span class="level-badge">Pro · 하드코어</span>
        </div>
      </div>
    </div>

    <h3>당신의 스타트업 아이디어</h3>
    <textarea id="ideaInput" placeholder="당신의 스타트업 아이디어를 자세히 설명해주세요.

예시:
- 어떤 문제를 해결하고 싶나요?
- 타겟 고객은 누구인가요?
- 어떤 방식으로 수익을 낼 계획인가요?"></textarea>
    <button id="submitBtn">AI 코파운더들에게 피칭하기</button>
  </div>

  <div class="loading" id="loading">
    <div class="spinner"></div>
    <p id="loadingText">4명의 AI 전문가가 아이디어를 뜯어보는 중입니다...</p>
  </div>

  <div class="result-section" id="resultSection">
    <div class="average-score" id="averageScore">
      <div class="score" id="scoreValue">--</div>
      <div class="score-change" id="scoreChange"></div>
      <div class="message" id="scoreMessage"></div>
      <p class="tip" id="scoreTip"></p>
    </div>

    <div class="combined-idea" id="combinedIdea" style="display:none;">
      <div class="combined-header">
        <span class="combined-title">보완된 아이디어 (전체 보기)</span>
        <span class="combined-count" id="combinedCount">0개 답변 반영</span>
      </div>
      <div class="combined-content" id="combinedContent"></div>
    </div>

    <div class="cards" id="cards"></div>
    <div class="btn-group">
      <button class="btn-secondary" id="resetBtn">처음부터 다시</button>
      <button class="btn-success" id="reEvaluateBtn" style="display:none;">AI에게 설득하기 (재평가)</button>
    </div>
  </div>

  <div class="modal-overlay" id="modalOverlay">
    <div class="modal">
      <h3>AI를 설득하세요!</h3>
      <p class="modal-role" id="modalRole"></p>
      <div class="modal-question" id="modalQuestion"></div>
      <div class="suggestions" id="suggestions">
        <p class="suggestions-title">AI 추천 답변 (클릭하여 선택)</p>
        <div id="suggestionsList"></div>
      </div>
      <div class="or-divider">또는 직접 작성</div>
      <textarea id="modalAnswer" placeholder="전문가를 설득할 수 있는 답변을 작성하세요..."></textarea>
      <div class="modal-buttons">
        <button class="btn-cancel" id="modalCancel">취소</button>
        <button id="modalSubmit">답변 추가</button>
      </div>
    </div>
  </div>

  <script>
    // State
    let currentIdea = '';
    let currentLevel = 'mvp';
    let supplements = [];
    let iteration = 0;
    let lastEvaluations = [];
    let previousScores = {};

    const LEVEL_NAMES = {
      sketch: '아이디어 스케치',
      mvp: 'MVP 빌딩',
      investor: '투자자 방어'
    };

    const ROLE_CONFIG = {
      PM: { label: '기획자 (PM)', className: 'pm', icon: 'P' },
      Developer: { label: '개발자 (Tech Lead)', className: 'developer', icon: 'D' },
      Designer: { label: '디자이너 (Design Lead)', className: 'designer', icon: 'U' },
      Investor: { label: '투자자 (Investor)', className: 'investor', icon: 'I' }
    };

    // Elements
    const ideaInput = document.getElementById('ideaInput');
    const submitBtn = document.getElementById('submitBtn');
    const inputSection = document.getElementById('inputSection');
    const loading = document.getElementById('loading');
    const loadingText = document.getElementById('loadingText');
    const resultSection = document.getElementById('resultSection');
    const averageScoreEl = document.getElementById('averageScore');
    const scoreValue = document.getElementById('scoreValue');
    const scoreChange = document.getElementById('scoreChange');
    const scoreMessage = document.getElementById('scoreMessage');
    const scoreTip = document.getElementById('scoreTip');
    const cardsEl = document.getElementById('cards');
    const resetBtn = document.getElementById('resetBtn');
    const reEvaluateBtn = document.getElementById('reEvaluateBtn');
    const combinedIdea = document.getElementById('combinedIdea');
    const combinedCount = document.getElementById('combinedCount');
    const combinedContent = document.getElementById('combinedContent');
    const iterationBadge = document.getElementById('iterationBadge');
    const iterationCount = document.getElementById('iterationCount');
    const levelIndicator = document.getElementById('levelIndicator');
    const modalOverlay = document.getElementById('modalOverlay');
    const modalRole = document.getElementById('modalRole');
    const modalQuestion = document.getElementById('modalQuestion');
    const modalAnswer = document.getElementById('modalAnswer');
    const modalCancel = document.getElementById('modalCancel');
    const modalSubmit = document.getElementById('modalSubmit');
    const suggestionsList = document.getElementById('suggestionsList');

    let currentModalData = null;

    // 난이도 선택
    window.selectLevel = function(level) {
      currentLevel = level;
      document.querySelectorAll('.level-card').forEach(card => {
        card.classList.toggle('selected', card.dataset.level === level);
      });
    };

    function updateCombinedIdea() {
      const answered = supplements.length;
      if (answered === 0) {
        combinedIdea.style.display = 'none';
        reEvaluateBtn.style.display = 'none';
        return;
      }

      combinedIdea.style.display = 'block';
      reEvaluateBtn.style.display = 'block';
      combinedCount.textContent = `${answered}개 답변 반영`;

      let html = `<div class="original">${currentIdea}</div>`;
      if (supplements.length > 0) {
        html += `<div class="supplement-section">`;
        supplements.forEach((s, i) => {
          const config = ROLE_CONFIG[s.role] || { label: s.role };
          html += `
            <div class="qa-item">
              <div class="qa-q">Q${i + 1}. [${config.label}] ${s.question}</div>
              <div class="qa-a">A${i + 1}. ${s.answer}</div>
            </div>
          `;
        });
        html += `</div>`;
      }
      combinedContent.innerHTML = html;
    }

    // 초기 평가
    async function evaluate() {
      const idea = ideaInput.value.trim();
      if (!idea) { alert('아이디어를 입력해주세요.'); return; }

      currentIdea = idea;
      iteration = 1;
      supplements = [];
      previousScores = {};

      iterationBadge.style.display = 'inline-block';
      iterationCount.textContent = iteration;
      levelIndicator.textContent = LEVEL_NAMES[currentLevel];
      levelIndicator.className = `level-indicator ${currentLevel}`;

      inputSection.style.display = 'none';
      loadingText.textContent = currentLevel === 'sketch'
        ? '친절한 멘토들이 아이디어를 살펴보는 중...'
        : currentLevel === 'investor'
        ? 'VC 심사역들이 날카롭게 검토하는 중...'
        : '4명의 AI 전문가가 아이디어를 뜯어보는 중입니다...';
      loading.classList.add('show');
      resultSection.classList.remove('show');

      try {
        const response = await fetch('/api/evaluate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idea, level: currentLevel })
        });
        const result = await response.json();
        if (!result.success) throw new Error(result.error);

        lastEvaluations = result.evaluations;
        result.evaluations.forEach(ev => { previousScores[ev.role] = ev.score; });
        renderResult(result.evaluations, false);
      } catch (error) {
        alert('평가 중 오류가 발생했습니다: ' + error.message);
        inputSection.style.display = 'block';
      } finally {
        loading.classList.remove('show');
      }
    }

    // 재평가
    async function reEvaluate() {
      if (supplements.length === 0) { alert('먼저 질문에 답변해주세요.'); return; }

      iteration++;
      iterationCount.textContent = iteration;
      loadingText.textContent = 'AI가 당신의 답변을 검토하고 있습니다...';
      loading.classList.add('show');
      resultSection.classList.remove('show');

      const evaluationsWithAnswers = lastEvaluations.map(ev => {
        const supplement = supplements.find(s => s.role === ev.role);
        return {
          role: ev.role,
          previous_score: ev.score,
          previous_feedback: ev.feedback,
          previous_key_question: ev.key_question,
          user_answer: supplement ? supplement.answer : null
        };
      });

      try {
        const response = await fetch('/api/re-evaluate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            original_idea: currentIdea,
            evaluations_with_answers: evaluationsWithAnswers,
            level: currentLevel
          })
        });
        const result = await response.json();
        if (!result.success) throw new Error(result.error);

        lastEvaluations.forEach(ev => { previousScores[ev.role] = ev.score; });
        lastEvaluations = result.evaluations;
        supplements = [];
        renderResult(result.evaluations, true);
      } catch (error) {
        alert('재평가 중 오류가 발생했습니다: ' + error.message);
        resultSection.classList.add('show');
      } finally {
        loading.classList.remove('show');
      }
    }

    submitBtn.addEventListener('click', evaluate);
    reEvaluateBtn.addEventListener('click', reEvaluate);

    resetBtn.addEventListener('click', () => {
      resultSection.classList.remove('show');
      inputSection.style.display = 'block';
      ideaInput.value = '';
      currentIdea = '';
      supplements = [];
      iteration = 0;
      lastEvaluations = [];
      previousScores = {};
      iterationBadge.style.display = 'none';
      combinedIdea.style.display = 'none';
      ideaInput.focus();
    });

    modalCancel.addEventListener('click', () => { modalOverlay.classList.remove('show'); currentModalData = null; });
    modalOverlay.addEventListener('click', (e) => { if (e.target === modalOverlay) { modalOverlay.classList.remove('show'); currentModalData = null; } });

    modalSubmit.addEventListener('click', () => {
      const answer = modalAnswer.value.trim();
      if (!answer) { alert('답변을 입력해주세요.'); return; }
      supplements = supplements.filter(s => s.role !== currentModalData.role);
      supplements.push({ role: currentModalData.role, question: currentModalData.question, answer });
      modalOverlay.classList.remove('show');
      modalAnswer.value = '';
      currentModalData = null;
      renderCards(false);
      updateCombinedIdea();
    });

    async function openAnswerModal(role, question) {
      currentModalData = { role, question };
      modalRole.textContent = ROLE_CONFIG[role]?.label || role;
      modalQuestion.textContent = question;
      modalAnswer.value = supplements.find(s => s.role === role)?.answer || '';
      suggestionsList.innerHTML = `<div class="suggestions-loading"><div class="mini-spinner"></div><span>답변 선택지 생성 중...</span></div>`;
      modalOverlay.classList.add('show');

      try {
        const response = await fetch('/api/suggest-answers', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idea: currentIdea, role, question, level: currentLevel })
        });
        const result = await response.json();
        if (result.success && result.suggestions) {
          renderSuggestions(result.suggestions);
        } else {
          suggestionsList.innerHTML = '<p style="color:#999;font-size:13px;">선택지를 불러오지 못했습니다.</p>';
        }
      } catch (error) {
        suggestionsList.innerHTML = '<p style="color:#999;font-size:13px;">선택지를 불러오지 못했습니다.</p>';
      }
    }

    function renderSuggestions(suggestions) {
      suggestionsList.innerHTML = suggestions.map((s, i) => `
        <div class="suggestion-item" onclick="selectSuggestion(${i})">
          <div class="suggestion-label">${s.label}</div>
          <div class="suggestion-answer">${s.answer}</div>
        </div>
      `).join('');
      window.suggestionData = suggestions;
    }

    window.selectSuggestion = function(index) {
      modalAnswer.value = window.suggestionData[index].answer;
      document.querySelectorAll('.suggestion-item').forEach((item, i) => {
        item.classList.toggle('selected', i === index);
      });
    };

    function renderCards(showScoreChange) {
      cardsEl.innerHTML = lastEvaluations.map(ev => {
        const config = ROLE_CONFIG[ev.role] || { label: ev.role, className: 'default', icon: '?' };
        const supplement = supplements.find(s => s.role === ev.role);
        const escapedQuestion = ev.key_question.replace(/`/g, "'").replace(/"/g, '&quot;');
        const isPassed = ev.score >= 80;

        const prevScore = previousScores[ev.role] || ev.score;
        const scoreDiff = ev.score - prevScore;
        let scoreChangeHtml = '';
        if (showScoreChange && scoreDiff !== 0) {
          const changeClass = scoreDiff > 0 ? 'up' : 'down';
          const changeSign = scoreDiff > 0 ? '+' : '';
          scoreChangeHtml = `<div class="card-score-change ${changeClass}">${changeSign}${scoreDiff}점</div>`;
        }

        const cardClass = `card ${config.className} ${supplement ? 'has-answer' : ''} ${showScoreChange && scoreDiff > 0 ? 'score-up' : ''}`;

        return `
          <div class="${cardClass}">
            <div class="card-header">
              <span class="card-role">${config.label}</span>
              <div class="card-score-wrap">
                <span class="card-score">${ev.score}점</span>
                ${scoreChangeHtml}
              </div>
            </div>
            <p class="card-feedback">${ev.feedback}</p>
            <div class="conversation">
              <div class="chat-bubble ai ${supplement ? 'answered' : ''} ${isPassed ? 'passed' : ''}"
                   onclick="${isPassed ? '' : `handleQuestionClick('${ev.role}', &quot;${escapedQuestion}&quot;)`}">
                <div class="chat-label">
                  <span class="icon">${config.icon}</span>
                  ${isPassed ? '검증 완료!' : `${config.label}의 질문`}
                </div>
                <div class="chat-content">${ev.key_question}</div>
                ${isPassed || supplement ? '' : '<span class="click-hint">클릭하여 답변하기</span>'}
              </div>
              ${supplement ? `
                <div class="chat-bubble user">
                  <div class="chat-label"><span class="icon">나</span>나의 답변</div>
                  <div class="chat-content">${supplement.answer}</div>
                  <button class="edit-answer" onclick="handleQuestionClick('${ev.role}', &quot;${escapedQuestion}&quot;)">수정하기</button>
                </div>
              ` : ''}
            </div>
          </div>
        `;
      }).join('');
    }

    function renderResult(evaluations, showScoreChange) {
      const scores = evaluations.map(e => e.score);
      const average = Math.round(scores.reduce((a, b) => a + b, 0) / scores.length);
      const isPassed = average >= 80;

      let avgChangeHtml = '';
      if (showScoreChange && Object.keys(previousScores).length > 0) {
        const prevAvg = Math.round(Object.values(previousScores).reduce((a, b) => a + b, 0) / Object.values(previousScores).length);
        const avgDiff = average - prevAvg;
        if (avgDiff !== 0) {
          const changeClass = avgDiff > 0 ? 'up' : 'down';
          const changeSign = avgDiff > 0 ? '+' : '';
          avgChangeHtml = `${changeSign}${avgDiff}점 ${avgDiff > 0 ? '상승!' : '하락'}`;
          scoreChange.className = `score-change ${changeClass}`;
        }
      }
      scoreChange.textContent = avgChangeHtml;

      scoreValue.textContent = average + '점';
      averageScoreEl.className = 'average-score ' + (isPassed ? 'pass' : 'fail');
      scoreMessage.textContent = isPassed
        ? '축하합니다! 팀 빌딩을 시작할 준비가 되었습니다!'
        : '보완이 필요합니다. AI의 질문에 답하며 아이디어를 발전시켜 보세요.';
      scoreTip.textContent = isPassed ? '' : '아래 핵심 질문을 클릭하여 AI를 설득하세요!';

      renderCards(showScoreChange);
      updateCombinedIdea();
      resultSection.classList.add('show');
    }

    window.handleQuestionClick = function(role, question) {
      const ev = lastEvaluations.find(e => e.role === role);
      if (ev && ev.score >= 80) return;
      openAnswerModal(role, question);
    };
  </script>
</body>
</html>
