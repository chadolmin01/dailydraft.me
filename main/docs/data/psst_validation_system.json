{
  "metadata": {
    "created_date": "2026-02-16",
    "purpose": "PSST 사업계획서 자동 검증 및 피드백 시스템",
    "version": "1.0"
  },
  "scoring_system": {
    "total_score": 100,
    "passing_score": 70,
    "sections": {
      "problem": {"weight": 20, "max_score": 20},
      "solution": {"weight": 30, "max_score": 30},
      "scaleup": {"weight": 30, "max_score": 30},
      "team": {"weight": 20, "max_score": 20}
    }
  },
  "validation_rules": {
    "problem": {
      "checks": [
        {
          "id": "P001",
          "name": "고객 관점 서술",
          "description": "창업자가 아닌 고객 관점에서 문제 서술",
          "check_method": "contains_customer_perspective",
          "keywords_positive": ["고객", "사용자", "소비자", "이용자", "~의 N%가"],
          "keywords_negative": ["우리는", "저는", "내가"],
          "weight": 3,
          "feedback_fail": "문제를 고객 관점에서 다시 서술해주세요. '고객의 N%가 ~를 경험한다' 형식을 권장합니다."
        },
        {
          "id": "P002",
          "name": "정량적 데이터 포함",
          "description": "통계, 수치, 퍼센트 등 정량 데이터 포함 여부",
          "check_method": "contains_numbers",
          "min_numbers": 3,
          "weight": 4,
          "feedback_fail": "정량적 데이터가 부족합니다. 통계, 설문 결과, 시장 데이터 등 숫자를 추가해주세요."
        },
        {
          "id": "P003",
          "name": "출처 명시",
          "description": "데이터 출처 표기 여부",
          "check_method": "contains_source",
          "patterns": ["출처:", "자료:", "(\\d{4})", "조사", "통계청", "연구"],
          "weight": 2,
          "feedback_fail": "데이터 출처를 명시해주세요. (예: '통계청, 2024' 또는 '자체 설문조사 N명')"
        },
        {
          "id": "P004",
          "name": "기존 솔루션 한계",
          "description": "현재 시장의 대안/경쟁 솔루션 한계점 언급",
          "check_method": "contains_keywords",
          "keywords": ["기존", "현재", "한계", "문제점", "부족", "불편", "비용"],
          "min_matches": 2,
          "weight": 3,
          "feedback_fail": "기존 솔루션의 한계점을 명시해주세요. 왜 현재 대안이 충분하지 않은지 설명이 필요합니다."
        },
        {
          "id": "P005",
          "name": "문제 개수 적정성",
          "description": "문제가 1-3개로 제한되어 있는지",
          "check_method": "count_problems",
          "min": 1,
          "max": 3,
          "weight": 2,
          "feedback_fail": "문제는 1-3개로 집중해주세요. 너무 많은 문제는 초점을 흐립니다."
        },
        {
          "id": "P006",
          "name": "형용사 남용 체크",
          "description": "추상적 형용사 과다 사용 여부",
          "check_method": "check_adjectives",
          "forbidden_words": ["매우", "굉장히", "엄청난", "혁신적인", "획기적인", "최고의", "최초의"],
          "max_allowed": 1,
          "weight": 2,
          "feedback_fail": "추상적 형용사를 줄이고 구체적 수치로 대체해주세요. '매우 큰' → '연 1조원 규모의'"
        }
      ],
      "total_weight": 16
    },
    "solution": {
      "checks": [
        {
          "id": "S001",
          "name": "P-S 매칭",
          "description": "Problem에서 제시한 문제와 Solution이 1:1 매칭",
          "check_method": "match_problem_solution",
          "weight": 5,
          "feedback_fail": "Problem에서 제시한 각 문제에 대응하는 해결책을 명시해주세요."
        },
        {
          "id": "S002",
          "name": "고객 가치 명시",
          "description": "기술이 아닌 고객 가치 중심 서술",
          "check_method": "contains_value",
          "keywords": ["절감", "향상", "개선", "효율", "편리", "시간", "비용", "만족"],
          "min_matches": 2,
          "weight": 4,
          "feedback_fail": "기술 설명보다 고객이 얻는 가치를 강조해주세요. '~를 통해 N% 절감/향상'"
        },
        {
          "id": "S003",
          "name": "작동 방식 설명",
          "description": "How it works 설명 포함",
          "check_method": "contains_process",
          "patterns": ["단계", "→", "과정", "방식", "통해", "프로세스"],
          "weight": 3,
          "feedback_fail": "솔루션이 어떻게 작동하는지 단계별로 설명해주세요."
        },
        {
          "id": "S004",
          "name": "차별화 포인트",
          "description": "경쟁사 대비 차별점 명시",
          "check_method": "contains_differentiation",
          "keywords": ["차별", "다르게", "유일", "특허", "독자", "최초", "경쟁사", "기존"],
          "weight": 4,
          "feedback_fail": "경쟁사와 다른 점을 명확히 해주세요. 기술적/비즈니스적 차별점이 필요합니다."
        },
        {
          "id": "S005",
          "name": "MVP/개발 현황",
          "description": "현재 개발 상태 및 성과 포함",
          "check_method": "contains_traction",
          "keywords": ["MVP", "프로토타입", "베타", "출시", "테스트", "사용자", "고객"],
          "weight": 5,
          "feedback_fail": "현재 개발 현황을 추가해주세요. MVP, 베타 테스트, 초기 사용자 피드백 등."
        },
        {
          "id": "S006",
          "name": "핵심 기능 명시",
          "description": "주요 기능 3-5개 명시",
          "check_method": "count_features",
          "min": 3,
          "max": 5,
          "weight": 3,
          "feedback_fail": "핵심 기능을 3-5개로 정리해주세요. 너무 많으면 초점이 흐려집니다."
        }
      ],
      "total_weight": 24
    },
    "scaleup": {
      "checks": [
        {
          "id": "SC001",
          "name": "시장 규모 (TAM/SAM/SOM)",
          "description": "시장 규모 3단계 모두 포함",
          "check_method": "contains_market_size",
          "required": ["TAM", "SAM", "SOM"],
          "alternative_keywords": ["전체 시장", "유효 시장", "목표 시장"],
          "weight": 5,
          "feedback_fail": "TAM(전체 시장), SAM(유효 시장), SOM(목표 시장)을 모두 명시해주세요."
        },
        {
          "id": "SC002",
          "name": "시장 출처",
          "description": "시장 규모 데이터 출처 명시",
          "check_method": "market_has_source",
          "weight": 2,
          "feedback_fail": "시장 규모 데이터의 출처를 명시해주세요. (예: 'Statista, 2024')"
        },
        {
          "id": "SC003",
          "name": "수익 모델 명확성",
          "description": "수익 창출 방법 구체적 명시",
          "check_method": "contains_revenue_model",
          "keywords": ["수익", "매출", "가격", "구독", "수수료", "판매", "과금"],
          "weight": 5,
          "feedback_fail": "수익 모델을 구체적으로 명시해주세요. 어떻게 돈을 벌 것인지?"
        },
        {
          "id": "SC004",
          "name": "단계별 성장 전략",
          "description": "시장 진입 → 성장 → 확장 단계 구분",
          "check_method": "contains_stages",
          "patterns": ["1단계", "2단계", "3단계", "초기", "중기", "장기"],
          "min_stages": 2,
          "weight": 4,
          "feedback_fail": "시장 진입과 성장 전략을 단계별로 구분해주세요."
        },
        {
          "id": "SC005",
          "name": "마케팅/영업 채널",
          "description": "고객 확보 방법 구체화",
          "check_method": "contains_channels",
          "keywords": ["마케팅", "영업", "채널", "광고", "제휴", "파트너", "SNS", "B2B"],
          "weight": 3,
          "feedback_fail": "고객 확보 채널을 구체적으로 명시해주세요. 온라인/오프라인, B2B/B2C 등."
        },
        {
          "id": "SC006",
          "name": "자금 사용 계획",
          "description": "지원금 사용 계획 구체화",
          "check_method": "contains_fund_usage",
          "keywords": ["자금", "예산", "비용", "투입", "사용", "계획"],
          "weight": 4,
          "feedback_fail": "지원금 사용 계획을 항목별로 구체화해주세요. (예: 개발비 40%, 마케팅비 30%)"
        },
        {
          "id": "SC007",
          "name": "마일스톤 설정",
          "description": "시간별 목표와 KPI 설정",
          "check_method": "contains_milestones",
          "patterns": ["개월", "분기", "년", "목표", "KPI", "달성"],
          "weight": 3,
          "feedback_fail": "시간대별 마일스톤과 KPI를 설정해주세요. (예: '6개월 후 MAU 1만명')"
        }
      ],
      "total_weight": 26
    },
    "team": {
      "checks": [
        {
          "id": "T001",
          "name": "대표자 역량",
          "description": "대표자 관련 경력/전문성 명시",
          "check_method": "contains_founder_info",
          "keywords": ["대표", "CEO", "창업자", "경력", "년", "전문"],
          "weight": 4,
          "feedback_fail": "대표자의 관련 경력과 전문성을 구체적으로 명시해주세요."
        },
        {
          "id": "T002",
          "name": "역할 분담",
          "description": "팀원별 역할 명확히 구분",
          "check_method": "contains_roles",
          "keywords": ["개발", "마케팅", "영업", "기획", "디자인", "운영", "담당"],
          "min_roles": 2,
          "weight": 3,
          "feedback_fail": "팀원별 역할 분담을 명확히 해주세요. (개발, 마케팅, 운영 등)"
        },
        {
          "id": "T003",
          "name": "팀 차별적 강점",
          "description": "왜 이 팀이 성공할 수 있는지 설명",
          "check_method": "contains_team_strength",
          "keywords": ["강점", "경험", "네트워크", "전문성", "노하우", "역량"],
          "weight": 4,
          "feedback_fail": "'왜 이 팀이 이 사업을 성공시킬 수 있는가'에 대한 설명을 추가해주세요."
        },
        {
          "id": "T004",
          "name": "부족 역량 보완 계획",
          "description": "부족한 부분 인지 및 대응책",
          "check_method": "contains_gap_plan",
          "keywords": ["채용", "보완", "필요", "예정", "자문", "파트너"],
          "weight": 3,
          "feedback_fail": "부족한 역량이 있다면 어떻게 보완할 것인지 계획을 명시해주세요."
        }
      ],
      "total_weight": 14
    }
  },
  "overall_checks": {
    "structure": [
      {
        "id": "O001",
        "name": "분량 적정성",
        "check_method": "check_length",
        "min_chars": 3000,
        "max_chars": 15000,
        "feedback": "적정 분량: 3,000-15,000자. 현재 분량이 {current}자입니다."
      },
      {
        "id": "O002",
        "name": "섹션 완성도",
        "check_method": "check_sections",
        "required_sections": ["problem", "solution", "market", "team"],
        "feedback": "필수 섹션이 누락되었습니다: {missing}"
      }
    ],
    "style": [
      {
        "id": "O003",
        "name": "문장 길이",
        "check_method": "check_sentence_length",
        "max_avg_length": 50,
        "feedback": "문장이 너무 깁니다. 평균 40자 이내로 작성해주세요."
      },
      {
        "id": "O004",
        "name": "두괄식 구조",
        "check_method": "check_structure",
        "feedback": "각 섹션의 첫 문장에 핵심 결론을 배치해주세요."
      }
    ]
  },
  "feedback_templates": {
    "score_ranges": {
      "excellent": {"min": 90, "message": "훌륭합니다! 심사 통과 가능성이 높습니다."},
      "good": {"min": 80, "message": "잘 작성되었습니다. 아래 개선점을 보완하면 더 좋아집니다."},
      "fair": {"min": 70, "message": "기본은 갖추었지만, 개선이 필요한 부분이 있습니다."},
      "needs_work": {"min": 50, "message": "상당한 보완이 필요합니다. 아래 피드백을 참고해주세요."},
      "insufficient": {"min": 0, "message": "전면적인 재작성이 필요합니다."}
    },
    "section_feedback": {
      "header": "## {section_name} 섹션 평가\n점수: {score}/{max_score}",
      "passed": "✅ {check_name}: 충족",
      "failed": "❌ {check_name}: 미충족\n   → {feedback}"
    }
  },
  "auto_improvement_suggestions": {
    "number_conversion": {
      "trigger": "형용사 남용",
      "examples": [
        {"before": "매우 큰 시장", "after": "연 1조원 규모의 시장"},
        {"before": "빠르게 성장하는", "after": "연평균 25% 성장하는"},
        {"before": "많은 고객", "after": "월 10만명의 고객"},
        {"before": "혁신적인 기술", "after": "처리 속도 3배 향상된 기술"}
      ]
    },
    "structure_improvement": {
      "trigger": "두괄식 미준수",
      "instruction": "각 섹션의 첫 문장을 핵심 결론으로 시작하세요.",
      "example": {
        "before": "저희 팀은 오랜 기간 이 문제에 대해 고민해왔습니다. 결과적으로 시장에는 효과적인 솔루션이 부재합니다.",
        "after": "현재 시장에는 효과적인 솔루션이 부재합니다. 저희 팀은 5년간 이 문제를 연구하며 해결책을 개발했습니다."
      }
    }
  }
}
