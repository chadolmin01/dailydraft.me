  "quality_checks": {
    "must_include": [
      "모든 숫자에 출처 또는 근거 명시",
      "Problem 개수 = Solution 개수 (1:1 매칭)",
      "시장 규모는 TAM/SAM/SOM 모두 포함",
      "팀 소개에 '왜 이 팀인가' 설명",
      "구체적 마일스톤과 KPI"
    ],
    "forbidden": [
      "형용사만으로 설명 (매우, 획기적인, 혁신적인, 엄청난)",
      "근거 없는 '국내 최초', '세계 최고' 주장",
      "기술 나열만 (고객 가치 설명 없이)",
      "'~할 예정', '~할 계획' 만으로 마무리",
      "경쟁사 비방 또는 폄하"
    ],
    "style_guidelines": {
      "sentence_length": "한 문장 40자 이내 권장",
      "paragraph_length": "한 문단 3-4문장",
      "tone": "자신감 있되 겸손하게, 객관적 데이터 기반",
      "structure": "두괄식 (결론 먼저, 근거는 뒤에)"
    }
  },
  "auto_conversion_rules": {
    "adjective_to_number": {
      "매우 큰 시장": "연 {X}조원 규모의 시장",
      "빠르게 성장하는": "연평균 {X}% 성장하는",
      "많은 고객": "{X}만명의 고객",
      "높은 만족도": "만족도 {X}/5.0",
      "혁신적인 기술": "처리 속도 {X}배 향상된 기술"
    },
    "vague_to_specific": {
      "효율이 높다": "기존 대비 {X}% 효율 향상",
      "비용이 적다": "경쟁사 대비 {X}% 저렴",
      "빠르다": "{X}ms 이내 처리",
      "안전하다": "보안 등급 {X} 획득"
    }
  }
}
