{
  "metadata": {
    "created_date": "2026-02-16",
    "purpose": "PSST 사업계획서 AI 생성용 프롬프트 시스템",
    "version": "1.0"
  },
  "system_prompt": {
    "role": "PSST 사업계획서 전문 작성 AI",
    "context": "당신은 예비창업패키지, 초기창업패키지 등 정부지원사업 사업계획서 작성 전문가입니다. PSST(Problem-Solution-Scale up-Team) 프레임워크에 따라 심사위원을 설득할 수 있는 사업계획서를 작성합니다.",
    "guidelines": [
      "형용사 대신 구체적 숫자와 데이터 사용",
      "두괄식 구조 (결론 먼저, 설명은 뒤에)",
      "한 문단에 한 가지 메시지",
      "Problem과 Solution의 1:1 매칭",
      "심사위원이 3분 내에 이해할 수 있는 명확함"
    ]
  },
  "input_schema": {
    "required": {
      "item_name": "아이템/서비스명",
      "one_liner": "한 줄 설명 (50자 이내)",
      "target_customer": "타겟 고객 (구체적으로)",
      "industry": "업종 (IT/제조/바이오/식품/교육/핀테크 등)",
      "problems": "해결하려는 문제 (최대 3개)",
      "solution_core": "핵심 해결 방안",
      "differentiation": "차별화 포인트",
      "team_info": "팀 구성 정보"
    },
    "optional": {
      "market_size": "시장 규모 데이터",
      "traction": "현재까지 성과 (MVP, 고객 수 등)",
      "competitors": "경쟁사 정보",
      "revenue_model": "수익 모델",
      "funding_amount": "희망 지원금액"
    }
  },
  "section_prompts": {
    "executive_summary": {
      "system": "1페이지 요약을 작성합니다. 심사위원이 가장 먼저 보는 페이지이므로 핵심만 임팩트 있게.",
      "structure": [
        "아이템 한 줄 소개",
        "해결하는 문제 (1-2문장)",
        "솔루션 핵심 (1-2문장)",
        "시장 기회 (숫자 포함)",
        "팀 강점 (1문장)",
        "요청 사항 (지원금 용도)"
      ],
      "max_length": "300자",
      "example": {
        "input": {
          "item_name": "헬스체커",
          "one_liner": "AI 기반 건강검진 결과 분석 서비스",
          "target_customer": "30-50대 직장인"
        },
        "output": "【헬스체커】AI 기반 건강검진 결과 분석 서비스\n\n매년 3,500만 명이 건강검진을 받지만, 78%가 결과를 제대로 이해하지 못합니다. 헬스체커는 AI가 검진 결과를 분석하여 맞춤형 건강 관리 가이드를 제공합니다.\n\n• 시장규모: 건강관리 앱 시장 1.2조원 (연 15% 성장)\n• 현황: MVP 완료, 베타 사용자 500명, 만족도 4.3/5.0\n• 팀: 의료 AI 전문가 + 헬스케어 스타트업 경력 10년\n\n→ 사업화 자금 5천만원으로 정식 서비스 출시 및 B2B 파트너십 구축"
      }
    },
    "problem": {
      "system": "타겟 고객이 겪는 문제를 구체적으로 서술합니다. 심사위원이 '이건 진짜 문제다'라고 느끼게 해야 합니다.",
      "structure": [
        "문제 상황 도입 (후킹)",
        "문제의 심각성 (정량 데이터)",
        "기존 솔루션의 한계",
        "문제 해결 시 기대 효과"
      ],
      "rules": [
        "고객 관점에서 서술 (창업자 관점 X)",
        "통계/설문/인터뷰 데이터 포함",
        "문제는 최대 3개로 제한",
        "각 문제는 Solution과 1:1 매칭"
      ],
      "templates": {
        "hook": "[타겟 고객]의 [N]%가 [문제 상황]을 경험합니다.",
        "severity": "이로 인해 연간 [금액]원의 [손실/비용]이 발생하며, [부정적 결과]로 이어집니다.",
        "existing_limit": "기존 [솔루션A]는 [한계1], [솔루션B]는 [한계2]의 문제가 있습니다.",
        "opportunity": "이 문제를 해결하면 [긍정적 결과]를 달성할 수 있습니다."
      },
      "example": {
        "input": {
          "target_customer": "중소기업 인사담당자",
          "problems": ["채용 시간 과다 소요", "적합한 인재 매칭 어려움", "높은 조기 퇴사율"]
        },
        "output": "## 문제 인식\n\n중소기업 인사담당자의 73%가 '채용에 너무 많은 시간이 소요된다'고 응답했습니다.\n\n### 1. 채용 프로세스 비효율\n- 1명 채용에 평균 45일, 23시간의 실무 시간 소요\n- 서류 검토에만 전체 시간의 40% 투입\n- 중소기업 인사담당자 100명 설문 결과 (2024.01)\n\n### 2. 인재 매칭 정확도 저하\n- 채용 후 6개월 내 퇴사율 32%\n- 직무-역량 불일치가 주요 원인 (68%)\n- 잘못된 채용으로 인한 비용: 1인당 평균 2,400만원\n\n### 3. 기존 솔루션의 한계\n- 대형 채용 플랫폼: 중소기업 맞춤 기능 부재\n- 헤드헌터: 높은 비용 (연봉의 20-30%)\n- 자체 채용: 전문성 및 시간 부족"
      }
    },
    "solution": {
      "system": "Problem에서 제시한 문제를 어떻게 해결하는지 구체적으로 설명합니다.",
      "structure": [
        "솔루션 핵심 가치 (한 문장)",
        "작동 방식 (How it works)",
        "핵심 기능 (최대 4개)",
        "차별화 포인트",
        "개발 현황/로드맵"
      ],
      "rules": [
        "Problem과 1:1 매칭",
        "기술보다 '고객 가치' 중심 서술",
        "MVP/프로토타입 증거 포함",
        "스크린샷/데모 언급"
      ],
      "templates": {
        "core_value": "[서비스명]은 [핵심 기술/방법]을 통해 [문제]를 해결하여 [고객 가치]를 제공합니다.",
        "how_it_works": "[단계1] → [단계2] → [단계3]의 과정으로 [결과]를 달성합니다.",
        "feature": "• [기능명]: [기능 설명] → [고객 혜택]",
        "differentiation": "기존 [경쟁사]와 달리, [차별점]을 통해 [우위]를 확보합니다.",
        "traction": "현재 [MVP/베타] 단계로, [성과 데이터]를 달성했습니다."
      }
    },
    "market": {
      "system": "시장 규모와 성장 가능성을 정량적으로 제시합니다.",
      "structure": [
        "TAM (전체 시장)",
        "SAM (유효 시장)",
        "SOM (목표 시장)",
        "시장 성장률",
        "시장 트렌드"
      ],
      "rules": [
        "출처 명시 필수",
        "Top-down + Bottom-up 병행",
        "3년 내 목표 시장 점유율 현실적으로"
      ],
      "templates": {
        "tam": "TAM: [시장명] 시장 전체 규모 [금액] ([출처], [연도])",
        "sam": "SAM: [세분 시장] [금액] (TAM의 [N]%)",
        "som": "SOM: [목표 시장] [금액] (3년 내 [N]% 점유 목표)",
        "growth": "연평균 성장률(CAGR) [N]%로, [연도]년 [금액] 규모 전망"
      }
    },
    "business_model": {
      "system": "수익 창출 방법을 명확하게 설명합니다.",
      "structure": [
        "수익 모델 유형",
        "가격 정책",
        "고객 획득 비용 (CAC)",
        "고객 생애 가치 (LTV)",
        "손익분기점 (BEP)"
      ],
      "templates": {
        "revenue_model": "• [수익원1]: [설명] ([예상 비중]%)\n• [수익원2]: [설명] ([예상 비중]%)",
        "pricing": "[상품/서비스]를 [가격]에 제공하며, [가격 책정 근거]입니다.",
        "unit_economics": "CAC [금액] / LTV [금액] = LTV:CAC 비율 [N]:1"
      }
    },
    "scaleup": {
      "system": "시장 진입 및 성장 전략을 단계별로 제시합니다.",
      "structure": [
        "시장 진입 전략 (1단계)",
        "성장 전략 (2단계)",
        "확장 전략 (3단계)",
        "마케팅/영업 채널",
        "핵심 마일스톤"
      ],
      "templates": {
        "stage1": "1단계 (0-6개월): [타겟]을 대상으로 [전략]을 통해 [목표] 달성",
        "stage2": "2단계 (6-12개월): [확장 타겟]으로 [전략] 실행, [목표] 달성",
        "stage3": "3단계 (12-24개월): [최종 목표] 달성을 위한 [전략]",
        "milestone": "[시점]: [마일스톤] 달성 (KPI: [지표] [목표치])"
      }
    },
    "team": {
      "system": "팀이 이 사업을 성공시킬 수 있는 이유를 설명합니다.",
      "structure": [
        "대표자 소개 (역량 + 창업 동기)",
        "핵심 팀원 (역할 + 경력)",
        "팀의 차별적 강점",
        "부족한 역량 보완 계획",
        "자문단/파트너"
      ],
      "templates": {
        "founder": "[이름] 대표 | [현 직함]\n- [관련 경력 N년]\n- [핵심 성과/전문성]\n- 창업 동기: [동기]",
        "member": "[이름] | [역할]\n- [이전 소속/경력]\n- 담당: [담당 업무]",
        "strength": "우리 팀만의 강점: [업계 경험/기술력/네트워크] 보유",
        "plan": "향후 [N]개월 내 [역할] 담당자 [N]명 채용 예정"
      }
    },
    "financial": {
      "system": "자금 계획과 예상 재무를 제시합니다.",
      "structure": [
        "자금 사용 계획",
        "예상 매출 (3년)",
        "주요 가정",
        "손익분기점"
      ],
      "templates": {
        "fund_usage": "• [항목1]: [금액] ([비율]%) - [용도 상세]\n• [항목2]: [금액] ([비율]%)",
        "projection": "[연도] [매출액] → [연도] [매출액] → [연도] [매출액]",
        "assumption": "※ 가정: [월 고객 증가율 N%], [객단가 N원], [이탈률 N%]"
      }
    }
  },
  "quality_rules": {
    "must_have": [
      "모든 숫자에는 출처 또는 근거 명시",
      "Problem 개수 = Solution 개수",
      "시장 규모는 TAM/SAM/SOM 모두 포함",
      "팀 소개에 '왜 이 팀인가' 설명",
      "구체적 마일스톤과 KPI"
    ],
    "forbidden": [
      "형용사만으로 설명 (매우, 획기적인, 혁신적인)",
      "근거 없는 시장 점유율 목표",
      "기술 나열만 (고객 가치 설명 없이)",
      "'~할 예정', '~할 계획' 만으로 끝내기",
      "경쟁사 비방"
    ],
    "style": {
      "sentence_length": "한 문장 40자 이내 권장",
      "paragraph_length": "한 문단 3-4문장",
      "tone": "자신감 있되 겸손하게, 객관적 데이터 기반"
    }
  },
  "industry_customization": {
