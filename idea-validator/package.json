{
  "name": "idea-validator",
  "version": "1.0.0",
  "description": "AI Co-founders Idea Validation Prototype",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
