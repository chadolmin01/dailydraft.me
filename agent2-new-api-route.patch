+import { NextRequest, NextResponse } from 'next/server'
+import { createClient } from '@/src/lib/supabase/server'
+import { notifyTeammateUpdate } from '@/src/lib/notifications/create-notification'
+
+// POST: Create a project update and notify teammates
+export async function POST(request: NextRequest) {
+  try {
+    const supabase = await createClient()
+    const { data: { user } } = await supabase.auth.getUser()
+    if (!user) {
+      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
+    }
+
+    const body = await request.json()
+    const { opportunity_id, week_number, title, content, update_type, done_text, next_text, blocker_text, image_url, is_public } = body
+
+    if (!opportunity_id || !week_number || !title || !content) {
+      return NextResponse.json({ error: 'Missing required fields' }, { status: 400 })
+    }
+
+    // Insert the update
+    const { data: update, error } = await supabase
+      .from('project_updates')
+      .insert({
+        opportunity_id,
+        author_id: user.id,
+        week_number,
+        title,
+        content,
+        update_type: update_type || 'general',
+        done_text: done_text || null,
+        next_text: next_text || null,
+        blocker_text: blocker_text || null,
+        image_url: image_url || null,
+        is_public: is_public || false,
+      })
+      .select()
+      .single()
+
+    if (error) throw error
+
+    // Get project title and author name for notification
+    const [oppResult, profileResult] = await Promise.all([
+      supabase.from('opportunities').select('title, creator_id').eq('id', opportunity_id).single(),
+      supabase.from('profiles').select('nickname').eq('user_id', user.id).single(),
+    ])
+
+    const projectTitle = oppResult.data?.title || 'Unknown Project'
+    const authorName = profileResult.data?.nickname || 'Anonymous'
+
+    // Find teammates: accepted_connections for this opportunity
+    const { data: connections } = await supabase
+      .from('accepted_connections')
+      .select('applicant_id, opportunity_creator_id')
+      .eq('opportunity_id', opportunity_id)
+
+    if (connections && connections.length > 0) {
+      // Collect all unique teammate user IDs (excluding the author)
+      const teammateIds = new Set<string>()
+      for (const conn of connections) {
+        if (conn.applicant_id !== user.id) teammateIds.add(conn.applicant_id)
+        if (conn.opportunity_creator_id !== user.id) teammateIds.add(conn.opportunity_creator_id)
+      }
+
+      // Also notify the project creator if they're not the author
+      if (oppResult.data?.creator_id && oppResult.data.creator_id !== user.id) {
+        teammateIds.add(oppResult.data.creator_id)
+      }
+
+      // Send notifications (fire and forget, don't block response)
+      const notifyPromises = [...teammateIds].map((id) =>
+        notifyTeammateUpdate(id, authorName, projectTitle, opportunity_id)
+      )
+      Promise.allSettled(notifyPromises).catch(() => {})
+    }
+
+    return NextResponse.json(update)
+  } catch (error) {
+    console.error('[project-updates] POST error:', error)
+    return NextResponse.json({ error: 'Failed to create update' }, { status: 500 })
+  }
+}
