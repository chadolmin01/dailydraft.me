+export async function notifyTeammateUpdate(
+  teammateUserId: string,
+  authorName: string,
+  projectTitle: string,
+  opportunityId: string
+) {
+  return createNotification({
+    userId: teammateUserId,
+    type: 'teammate_update',
+    title: '팀원이 주간 업데이트를 남겼어요',
+    message: `${authorName}님이 "${projectTitle}" 주간 업데이트를 작성했습니다.`,
+    link: `/explore?project=${opportunityId}`,
+    metadata: {
+      opportunity_id: opportunityId,
+      opportunity_title: projectTitle,
+      author_name: authorName,
+    },
+  })
+}
