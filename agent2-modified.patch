+// Calculate streak (consecutive weeks with updates) for a project
+export function useUpdateStreak(opportunityId: string | undefined) {
+  return useQuery({
+    queryKey: projectUpdateKeys.streak(opportunityId ?? ''),
+    staleTime: 1000 * 60 * 5,
+    queryFn: async () => {
+      if (!opportunityId) return 0
+
+      const { data, error } = await supabase
+        .from('project_updates')
+        .select('week_number')
+        .eq('opportunity_id', opportunityId)
+        .order('week_number', { ascending: false })
+
+      if (error) throw error
+      if (!data || data.length === 0) return 0
+
+      // Count consecutive weeks from the latest
+      const weeks = [...new Set(data.map((d) => d.week_number))].sort((a, b) => b - a)
+      let streak = 1
+      for (let i = 1; i < weeks.length; i++) {
+        if (weeks[i - 1] - weeks[i] === 1) {
+          streak++
+        } else {
+          break
+        }
+      }
+      return streak
+    },
+    enabled: !!opportunityId,
+  })
+}
+
