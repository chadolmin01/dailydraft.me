+      const res = await fetch(`/api/project-updates/feed?limit=${limit}`)
+      if (!res.ok) throw new Error('Failed to fetch public updates')
+      return res.json() as Promise<{ updates: PublicFeedUpdate[]; total: number }>
+    },
+  })
