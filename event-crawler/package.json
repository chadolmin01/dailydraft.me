{
  "name": "event-crawler",
  "version": "1.0.0",
  "description": "Web/SNS crawler for startup events collection",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "crawl": "tsx scripts/run-crawler.ts",
    "crawl:contestkorea": "tsx scripts/run-crawler.ts --source=contestkorea",
    "crawl:linkareer": "tsx scripts/run-crawler.ts --source=linkareer",
    "crawl:onoffmix": "tsx scripts/run-crawler.ts --source=onoffmix",
    "crawl:devpost": "tsx scripts/run-crawler.ts --source=devpost",
    "crawl:naver": "tsx scripts/run-crawler.ts --source=naver",
    "crawl:all": "tsx scripts/run-crawler.ts --source=all",
    "cache": "tsx scripts/cache-manager.ts",
    "cache:stats": "tsx scripts/cache-manager.ts --action=stats",
    "cache:clear": "tsx scripts/cache-manager.ts --action=clear",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "@upstash/redis": "^1.28.0",
    "p-queue": "^8.0.0",
    "puppeteer": "^22.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
