# Supabase (Direct DB mode)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Backend API (API mode - alternative to direct DB)
BACKEND_API_URL=http://localhost:3000
CRON_SECRET=your_cron_secret

# Naver Search API (https://developers.naver.com/)
# 무료: 25,000 calls/day
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Twitter API (optional)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Upstash Redis Cache
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Crawler settings
CRAWL_DELAY_MS=3000
MAX_CONCURRENT_REQUESTS=2
USER_AGENT=EventCrawlerBot/1.0 (+https://yoursite.com/bot)

# Optional: Proxy settings (for rate limiting bypass)
# PROXY_URL=http://proxy:port

# Logging
LOG_LEVEL=info
